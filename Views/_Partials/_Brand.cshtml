@{
  var svgWidth = "25";
}

<span class="text-primary">
    <svg width="@svgWidth" xmlns="http://www.w3.org/2000/svg" viewBox="20 15 80 90">
        <!-- report sheet -->
        <rect x="20" y="15" width="80" height="90" rx="10" fill="#003A8F" />

        <!-- chart bars -->
        <rect x="35" y="70" width="10" height="20" fill="#ffffff" />
        <rect x="55" y="55" width="10" height="35" fill="#ffffff" />
        <rect x="75" y="40" width="10" height="50" fill="#ffffff" />

        <!-- connection line -->
        <circle cx="40" cy="35" r="4" fill="#ffffff" />
        <circle cx="60" cy="30" r="4" fill="#ffffff" />
        <circle cx="80" cy="25" r="4" fill="#ffffff" />
        <path d="M40 35 L60 30 L80 25" stroke="#ffffff" stroke-width="3" fill="none" />
    </svg>
</span>
