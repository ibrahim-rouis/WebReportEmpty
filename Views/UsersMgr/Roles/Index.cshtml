@using WebReport.Models.Common
@using WebReport.Models.Entities
@using System.Text.Json
@model PaginatedList<Role>

@{
    ViewData["Title"] = "Index";
    int totalPages = Model.TotalPages;
    int currentPage = Model.PageIndex;
    int maxPagesToShow = 5;
    int startPage = 1;
    int endPage = totalPages;
    var searchString = ViewData["SearchString"] as string ?? "";


    if (totalPages > maxPagesToShow)
    {
        if (currentPage <= 3)
        {
            startPage = 1;
            endPage = maxPagesToShow;
        }
        else if (currentPage + 2 >= totalPages)
        {
            startPage = totalPages - maxPagesToShow + 1;
            endPage = totalPages;
        }
        else
        {
            startPage = currentPage - 2;
            endPage = currentPage + 2;
        }
    }
}

<!-- Menu -->
<div class="card-body mb-3">
    <a asp-action="Create" class="btn rounded-pill btn-primary">Create Role</a>
</div>

<!-- Filter Card -->
<div class="card mb-4">
    <h5 class="card-header py-2">Filter</h5>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label"><i class="fas fa-search"></i> Search</label>
                    <input type="text" name="searchString" class="form-control form-control-sm"
                           placeholder="Search..." value="@ViewData["SearchString"]" />
                </div>
                <div class="col-auto d-flex justify-content-end">
                    <button type="submit" class="btn btn-icon rounded-pill btn-primary me-2" title="Search">
                        <span class="icon-base bx bx-search icon-md"></span>
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-icon rounded-pill btn-secondary me-2" title="Reset">
                        <span class="icon-base bx bx-undo icon-md"></span>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Basic Bootstrap Table -->
<div class="card">
    <h5 class="card-header">Roles</h5>
    <div class="table-responsive text-nowrap">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th width="10%">Id</th>
                    <th width="60%">Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @foreach (var item in Model)
                {
                    <tr id="role-row-@item.Id">
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>
                            <button type="button" class="btn btn-icon btn-outline-danger mx-1 delete-btn" data-role-id="@item.Id" data-role-name="@item.Name">
                                <span class="icon-base bx bx-trash icon-md text-danger"></span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Basic Pagination -->
<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mt-5">
        @if (Model.HasPreviousPage)
        {
            <li class="page-item first">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="1"><i class="icon-base bx bx-chevrons-left icon-sm"></i></a>
            </li>
            <li class="page-item prev">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(currentPage - 1)"><i class="icon-base bx bx-chevron-left icon-sm"></i></a>
            </li>
        }
        else
        {
            <li class="page-item first disabled">
                <a class="page-link" href="javascript:void(0);"><i class="icon-base bx bx-chevrons-left icon-sm"></i></a>
            </li>
            <li class="page-item prev disabled">
                <a class="page-link" href="javascript:void(0);"><i class="icon-base bx bx-chevron-left icon-sm"></i></a>
            </li>
        }

        @for (int i = startPage; i <= endPage; i++)
        {
            @if (i == currentPage)
            {
                <li class="page-item active">
                    <a class="page-link" href="javascript:void(0);">@i</a>
                </li>
            }
            else
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@i">@i</a>
                </li>
            }
        }

        @if (Model.HasNextPage)
        {
            <li class="page-item next">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(currentPage + 1)"><i class="icon-base bx bx-chevron-right icon-sm"></i></a>
            </li>
            <li class="page-item last">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(totalPages)"><i class="icon-base bx bx-chevrons-right icon-sm"></i></a>
            </li>
        }
        else
        {
            <li class="page-item next disabled">
                <a class="page-link" href="javascript:void(0);"><i class="icon-base bx bx-chevron-right icon-sm"></i></a>
            </li>
            <li class="page-item last disabled">
                <a class="page-link" href="javascript:void(0);"><i class="icon-base bx bx-chevrons-right icon-sm"></i></a>
            </li>
        }
    </ul>
</nav>
<!--/ Basic Pagination -->
<!--/ Basic Bootstrap Table -->
<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete role <span id="deleteRoleName"></span>?
            </div>
            <div class="modal-footer">
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteRoleId" name="id" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
    <script>
        let currentPage = "@currentPage";
        let searchString = @Html.Raw(JsonSerializer.Serialize(searchString));

        $('.delete-btn').on('click', function (e) {
            currentRoleId = $(this).data('role-id');
            var roleName = $(this).data('role-name');
            $('#deleteRoleId').val(currentRoleId);
            $('#deleteRoleName').text(roleName);
            $('#deleteModal').modal('show');
        });

        $('#confirmDeleteBtn').on('click', function () {
            var token = $('#deleteForm input[name="__RequestVerificationToken"]').val();
            $.ajax({
                url: '@Url.Action("Delete", "Roles")',
                type: 'POST',
                data: {
                    id: currentRoleId,
                    __RequestVerificationToken: token
                },
                success: function () {
                    // Refresh index with current page and searchString
                    var url = '@Url.Action("Index", "Roles")' + '?pageNumber=' + currentPage;
                    if (searchString) {
                        url += '&searchString=' + encodeURIComponent(searchString);
                    }
                    window.location.href = url;
                },
                error: function () {
                    alert('Delete failed.');
                }
            });
        });
    </script>
}