@using WebReport.Models.Common
@using WebReport.Models.Entities
@using System.Text.Json
@model PaginatedList<User>

@{
    ViewData["Title"] = "Index";
    int totalPages = Model.TotalPages;
    int currentPage = Model.PageIndex;
    int maxPagesToShow = 5;
    int startPage = 1;
    int endPage = totalPages;
    var searchString = ViewData["SearchString"] as string ?? "";

    // Calculate the range of page numbers to display in pagination
    if (totalPages > maxPagesToShow)
    {
        if (currentPage <= 3)
        {
            startPage = 1;
            endPage = maxPagesToShow;
        }
        else if (currentPage + 2 >= totalPages)
        {
            startPage = totalPages - maxPagesToShow + 1;
            endPage = totalPages;
        }
        else
        {
            startPage = currentPage - 2;
            endPage = currentPage + 2;
        }
    }
}

<!-- Actions Menu -->
<div class="card-body mb-3">
    <a asp-action="Create" class="btn rounded-pill btn-primary">Create User</a>
</div>
<!--/ Actions Menu -->
<!-- Table -->
<div class="card">
    <h5 class="card-header">Users</h5>
    <div class="table-responsive text-nowrap">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th width="10%">Id</th>
                    <th width="20%">Name</th>
                    <th width="60%">Roles</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @foreach (var item in Model)
                {
                    <tr id="user-row-@item.Id">
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>
                            @if (item.Roles != null && item.Roles.Any())
                            {
                                @string.Join(", ", item.Roles.Select(p => p.Name))
                            }
                            else
                            {
                                <span class="text-warning">No Roles</span>
                            }
                        </td>
                        <td>
                            <a class="btn btn-icon btn-outline-warning mx-1" asp-action="Edit" asp-route-id="@item.Id">
                                <span class="icon-base bx bx-edit-alt icon-md text-warning"></span>
                            </a>
                            <button type="button" class="btn btn-icon btn-outline-danger mx-1 delete-btn" data-user-id="@item.Id" data-user-name="@item.Name">
                                <span class="icon-base bx bx-trash icon-md text-danger"></span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<!--/ Table -->
<!-- Pagination -->
<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mt-5">
        @if (Model.HasPreviousPage)
        {
            <li class="page-item first">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="1"><i class="icon-base bx bx-chevrons-left icon-sm"></i></a>
            </li>
            <li class="page-item prev">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(currentPage - 1)"><i class="icon-base bx bx-chevron-left icon-sm"></i></a>
            </li>
        }
        else
        {
            <li class="page-item first disabled">
                <a class="page-link" href="javascript:void(0);"><i class="icon-base bx bx-chevrons-left icon-sm"></i></a>
            </li>
            <li class="page-item prev disabled">
                <a class="page-link" href="javascript:void(0);"><i class="icon-base bx bx-chevron-left icon-sm"></i></a>
            </li>
        }

        @for (int i = startPage; i <= endPage; i++)
        {
            @if (i == currentPage)
            {
                <li class="page-item active">
                    <a class="page-link" href="javascript:void(0);">@i</a>
                </li>
            }
            else
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@i">@i</a>
                </li>
            }
        }

        @if (Model.HasNextPage)
        {
            <li class="page-item next">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(currentPage + 1)"><i class="icon-base bx bx-chevron-right icon-sm"></i></a>
            </li>
            <li class="page-item last">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(totalPages)"><i class="icon-base bx bx-chevrons-right icon-sm"></i></a>
            </li>
        }
        else
        {
            <li class="page-item next disabled">
                <a class="page-link" href="javascript:void(0);"><i class="icon-base bx bx-chevron-right icon-sm"></i></a>
            </li>
            <li class="page-item last disabled">
                <a class="page-link" href="javascript:void(0);"><i class="icon-base bx bx-chevrons-right icon-sm"></i></a>
            </li>
        }
    </ul>
</nav>
<!--/ Pagination -->
<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete uer <span id="deleteUserName"></span>?
            </div>
            <div class="modal-footer">
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteUserId" name="id" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal Script -->
@section PageScripts {
    <script>
        let currentPage = "@currentPage";
        let searchString = "@searchString";

        $('.delete-btn').on('click', function (e) {
            currentUserId = $(this).data('user-id');
            var userName = $(this).data('user-name');
            $('#deleteUserId').val(currentUserId);
            $('#deleteUserName').text(userName);
            $('#deleteModal').modal('show');
        });

        $('#confirmDeleteBtn').on('click', function () {
            var token = $('#deleteForm input[name="__RequestVerificationToken"]').val();
            $.ajax({
                url: '@Url.Action("Delete", "Users")',
                type: 'POST',
                data: {
                    id: currentUserId,
                    __RequestVerificationToken: token
                },
                success: function () {
                    // Refresh index with current page and searchString
                    var url = '@Url.Action("Index", "Users")' + '?pageNumber=' + currentPage;
                    if (searchString) {
                        url += '&searchString=' + encodeURIComponent(searchString);
                    }
                    window.location.href = url;
                },
                error: function () {
                    alert('Delete failed.');
                }
            });
        });
    </script>
}
<!--/ Delete Confirmation Modal Script -->
<!--/ Delete Confirmation Modal -->